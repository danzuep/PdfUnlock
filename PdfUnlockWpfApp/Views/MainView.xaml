<UserControl x:Class="PdfUnlock.Wpf.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Opacity="0.08"
                                      Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F3F4F6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="760" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20" HorizontalAlignment="Stretch">

                <!-- Header -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="PDF Unlock"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <TextBlock Text="Unlock a protected PDF and save a new copy."
                                   Margin="0,6,0,0"
                                   Foreground="#6B7280"
                                   FontSize="14" />
                    </StackPanel>
                </Border>

                <!-- Input Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Input file"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <TextBlock Text="Choose the locked PDF file."
                                   Margin="0,4,0,10"
                                   Foreground="#6B7280"
                                   FontSize="12" />

                        <DockPanel LastChildFill="True">
                            <Button Content="Browse"
                                    Width="96"
                                    Margin="12,0,0,0"
                                    Command="{Binding BrowseInputCommand}"
                                    Background="#111827" />
                            <TextBox Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Locked PDF file path" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Password Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Password"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <TextBlock Text="Enter the password used to unlock the PDF."
                                   Margin="0,4,0,10"
                                   Foreground="#6B7280"
                                   FontSize="12" />

                        <Border BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                CornerRadius="12"
                                Background="White"
                                Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Hidden password -->
                                <PasswordBox x:Name="PasswordBox"
                                             Grid.Column="0"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             PasswordChanged="PasswordBox_OnPasswordChanged"
                                             ToolTip="Password" />

                                <!-- Optional reveal button -->
                                <ToggleButton x:Name="RevealPasswordToggle"
                                              Grid.Column="1"
                                              Width="44"
                                              BorderThickness="0"
                                              Background="Transparent"
                                              Margin="0"
                                              ToolTip="Show or hide password">
                                    <TextBlock Text="👁"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </ToggleButton>
                            </Grid>
                        </Border>

                        <!-- Revealed password overlay -->
                        <TextBox x:Name="PasswordRevealBox"
                                 Margin="0,-38,44,0"
                                 Visibility="Collapsed"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <!-- Output Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Output file"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <TextBlock Text="Select where the unlocked PDF should be saved."
                                   Margin="0,4,0,10"
                                   Foreground="#6B7280"
                                   FontSize="12" />

                        <DockPanel LastChildFill="True">
                            <Button Content="Browse"
                                    Width="96"
                                    Margin="12,0,0,0"
                                    Command="{Binding BrowseOutputCommand}"
                                    Background="#111827" />
                            <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Unlocked PDF output path" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Actions Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <CheckBox Content="Wait for close"
                                      IsChecked="{Binding WaitForClose}"
                                      VerticalAlignment="Center"
                                      Foreground="#374151" />
                        </StackPanel>

                        <Button Content="Unlock PDF"
                                Command="{Binding UnlockCommand}"
                                Width="160"
                                HorizontalAlignment="Right"
                                Background="#2563EB" />
                    </DockPanel>
                </Border>

                <!-- Status Card -->
                <Border Style="{StaticResource CardStyle}">
                    <DockPanel>
                        <TextBlock Text="Status"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Margin="0,0,12,0"
                                   DockPanel.Dock="Left" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#4B5563"
                                   TextWrapping="Wrap" />
                    </DockPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>